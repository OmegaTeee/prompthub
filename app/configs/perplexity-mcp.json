{
  "command": "node",
  "args": [
    "/Users/visualval/.local/share/prompthub/mcps/prompthub-bridge.js"
  ],
  "env": {
    "PROMPTHUB_URL": "http://localhost:9090",
    "AUTHORIZATION": "Bearer sk-prompthub-perplexity-search",
    "CLIENT_NAME": "perplexity"
  },
  "useBuiltInNode": true
}


{
  "mcpServers": {
    "prompthub": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${HOME}/.local/share/prompthub/mcps/prompthub-bridge.js"
      ],
      "env": {
        "AGENTHUB_URL": "http://localhost:9090",
        "AUTHORIZATION": "Bearer sk-prompthub-raycast",
        "CLIENT_NAME": "raycast"
      }
    }
  }
}
