{
  "servers": {
    "context7": {
      "package": "@upstash/context7-mcp",
      "transport": "stdio",
      "command": "node",
      "args": [
        "./mcps/node_modules/@upstash/context7-mcp/dist/index.js"
      ],
      "env": {},
      "auto_start": true,
      "restart_on_failure": true,
      "max_restarts": 3,
      "health_check_interval": 30,
      "description": "Documentation fetching from libraries"
    },
    "desktop-commander": {
      "package": "@wonderwhy-er/desktop-commander",
      "transport": "stdio",
      "command": "node",
      "args": [
        "./mcps/node_modules/@wonderwhy-er/desktop-commander/dist/index.js"
      ],
      "env": {
        "CLIENT_IP_ENCRYPTION_KEY": "3765aa62cca47c2929675c3a5e644775"
      },
      "auto_start": true,
      "restart_on_failure": true,
      "max_restarts": 3,
      "health_check_interval": 30,
      "description": "File operations and terminal commands"
    },
    "sequential-thinking": {
      "package": "@modelcontextprotocol/server-sequential-thinking",
