    "obsidian-mcp-tools": {
      "package": "obsidian-mcp-tools",
      "transport": "stdio",
      "command": "/Users/visualval/Vault/.obsidian/plugins/mcp-tools/bin/mcp-server",
      "args": [],
      "env": {
        "OBSIDIAN_API_KEY": {
          "source": "keyring",
          "service": "prompthub",
          "key": "obsidian_api_key"
        },
        "OBSIDIAN_AUTHENTICATION": {
          "source": "keyring",
          "service": "prompthub",
          "key": "obsidian_authentication"
        },
        "OBSIDIAN_HOST": "https://127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      },
      "auto_start": true,
      "restart_on_failure": true,
      "max_restarts": 3,
      "health_check_interval": 30,
      "description": "Obsidian vault operations via MCP Tools plugin"
    },
    "chrome-devtools-mcp": {
      "package": "chrome-devtools-mcp",
      "transport": "stdio",
      "command": "node",
      "args": [
        "./mcps/node_modules/chrome-devtools-mcp/build/src/bin/chrome-devtools-mcp.js",
        "--browserUrl",
        "http://127.0.0.1:9222",
        "--usageStatistics",
        "false"
      ],
      "env": {},
      "auto_start": false,
      "restart_on_failure": false,
      "max_restarts": 3,
      "health_check_interval": 30,
