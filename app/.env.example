# PromptHub Router Configuration
# Copy this to .env and customize

# Server
HOST=127.0.0.1
PORT=9090

# Ollama
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=deepseek-r1:latest
OLLAMA_TIMEOUT=30
# Enhancement backend format: "native" (/api/generate) or "openai" (/v1/chat/completions)
# This controls how the enhancement service talks to Ollama internally.
# The client-facing /v1/ proxy endpoints are always active regardless of this setting.
OLLAMA_API_MODE=native

# Data directory — persistent storage for cache, activity log, memory db
# Defaults to ~/.prompthub (XDG-style user data dir, survives reboots)
DATA_DIR=~/.prompthub

# Cache
CACHE_MAX_SIZE=1000
# Persistent L2 cache (SQLite write-through, survives restarts)
CACHE_PERSISTENT=false
# Individual DB/log paths — all default to $DATA_DIR/<name> if not set
# CACHE_DB_PATH=~/.prompthub/cache.db
# ACTIVITY_DB_PATH=~/.prompthub/activity.db
# MEMORY_DB_PATH=~/.prompthub/memory.db
# TOOL_REGISTRY_DB_PATH=~/.prompthub/tool_registry.db
# AUDIT_LOG_PATH=~/.prompthub/audit.log
# AUDIT_CHECKSUM_PATH=~/.prompthub/audit_checksums.json

# Circuit Breaker
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30

# Paths
MCP_SERVERS_CONFIG=configs/mcp-servers.json
ENHANCEMENT_RULES_CONFIG=configs/enhancement-rules.json
# OpenAI proxy bearer tokens (always active at /v1/ endpoints)
API_KEYS_CONFIG=configs/api-keys.json

# OpenRouter (cloud fallback for prompt enhancement)
# When Ollama is down, clients with privacy_level "free_ok" or "any" fall back to OpenRouter.
# Clients with "local_only" (the default) never use cloud fallback.
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=30
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-r1-0528:free

# Logging
LOG_LEVEL=info

# Secrets (load from Keychain in production)
# OBSIDIAN_API_KEY=
# GITHUB_TOKEN=
