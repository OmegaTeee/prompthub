{
  // ── Python environment ──────────────────────────────────
  // The project lives in app/ with its own venv
  "python.defaultInterpreterPath": "/Users/visualval/prompthub/app/.venv/bin/python",
  "python.envFile": "${workspaceFolder}/app/.env",
  "python.terminal.useEnvFile": true,
  "python-envs.pythonProjects": [
    {
      "path": "${workspaceFolder}/app/",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    },
    // {
    //   "path": "",
    //   "envManager": "ms-python.python:pipenv",
    //   "packageManager": "ms-python.python:pip"
    // }
  ],
  "python.terminal.activateEnvironment": true,
  // ── Static analysis (Pylance) ───────────────────────────
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/app"
  ],
  // ── Testing (pytest) ────────────────────────────────────
  // pytest runs from app/ where pyproject.toml lives
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.cwd": "${workspaceFolder}/app",
  "python.testing.pytestPath": "${workspaceFolder}/app/.venv/bin/pytest",
  "python.testing.pytestArgs": [
    "tests",
    "-q"
  ],
  // ── Formatting & linting (ruff) ─────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "ruff.configuration": "${workspaceFolder}/app/pyproject.toml",
  "ruff.cwd": "${workspaceFolder}/app",
  // ── Editor preferences ──────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true
  },
  "terminal.integrated.defaultProfile.osx": "PromptHub",
  "terminal.integrated.cwd": "app",
  // "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.env.osx": {
    "PATH": "${workspaceFolder}/app/.venv/bin:${env:PATH}",
    "USERHOME": "/Users/visualval"
  },
  "terminal.integrated.profiles.osx": {
    "PromptHub": {
      "path": "/bin/zsh",
      "args": [
        "-l"
      ],
      "cwd": "${workspaceFolder}"
    }
  },
  "chat.mcp.serverSampling": {
    "prompthub-bridge": {
      "allowedModels": [
        "*"
      ]
    }
  },
  "chat.tools.terminal.autoApprove": {
    "${workspaceFolder}/app/.venv/bin/python": true
  },
  "explorer.excludeGitIgnore": false,
  "explorer.autoReveal": false
}
