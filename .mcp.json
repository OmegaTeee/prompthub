{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${HOME}/.local/share/prompthub/mcps/node_modules/@upstash/context7-mcp/dist/index.js"
      ]
    },
    "deepseek-reasoner": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${HOME}/.local/share/prompthub/mcps/node_modules/deepseek-reasoner-mcp/dist/index.js"
      ]
    },
    "desktop-commander": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${HOME}/.local/share/prompthub/mcps/node_modules/@wonderwhy-er/desktop-commander/dist/index.js"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${HOME}/.local/share/prompthub/mcps/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "obsidian-mcp-tools": {
      "type": "stdio",
      "command": "${HOME}/Vault/.obsidian/plugins/mcp-tools/bin/mcp-server",
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_HOST": "https://127.0.0.1",
        "OBSIDIAN_PORT": "27124"
      }
    },
    "skills-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "skills-mcp",
        "-s",
        "${HOME}/.claude/skills"
      ]
    }
  }
}