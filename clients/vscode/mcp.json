{
	"servers": {
		"prompthub_bridge": {
			"name": "PromptHub Bridge",
			"type": "stdio",
			"command": "node",
			"args": [
				"mcp-bridge"
			],
			"env": {
				"CONTENT_TYPE": "application/json",
				"PROMPTHUB_URL": "http://127.0.0.1:9090",
				"AUTHORIZATION": "Bearer sk-prompthub-vscode-001",
				"CLIENT_NAME": "vscode",
				"SERVERS": "desktop-commander,context7,memory,sequential-thinking,duckduckgo"
			},
			"headers": {
				"Authorization": "Bearer sk-prompthub-vscode-001",
				"Content-Type": "application/json",
				"X-Client-Name": "vscode"
			}
		},
		"skills_mcp": {
			"name": "Skills MCP",
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"skills-mcp",
				"-s",
				"/Users/visualval/.claude/skills"
			]
		},
		"fetch_mcp": {
			"name": "Fetch MCP",
			"type": "stdio",
			"command": "mcp-server-fetch"
		},
		"markitdown_mcp": {
			"name": "Markitdown MCP",
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp"
			]
		}
	},
	"inputs": []
}
