		"*.sqlite": "${capture}.${extname}-*",
		"*.sqlite3": "${capture}.${extname}-*",
		"*.styl": "${capture}.styl.map",
		"*.ts": "${capture}.js, ${capture}.js.map",
		"*.tsx": "${capture}.ts, ${capture}.js, ${capture}.jsx, ${capture}.js.map",
		"package.json": "package-*.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
