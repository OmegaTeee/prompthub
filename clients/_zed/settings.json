{
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "show_wrap_guides": false,
  "agent_buffer_font_size": 13.0,
  "agent_ui_font_size": 15.0,
  "ui_font_family": "TT Text",
  "buffer_line_height": "comfortable",
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "edit_predictions": {
    "open_ai_compatible_api": {
      "prompt_format": "qwen",
    },
    "provider": "open_ai_compatible_api",
  },
  "language_models": {
    "openai_compatible": {},
  },
  "context_servers": {
    "prompthub": {
      "enabled": true,
      "remote": false,
      "command": "node",
      "args": ["/Users/visualval/prompthub/mcps/prompthub-bridge.js"],
      "env": {
        "AUTHORIZATION": "Bearer sk-lm-kDGwUvuD:XDCAUJUNxCPLHYPwOtIG",
        "CLIENT_NAME": "default",
        "PROMPTHUB_URL": "http://127.0.0.1:1234",
        "SERVERS": "memory,context7,sequential-thinking,desktop-commander,perplexity-comet",
      },
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "font_family": "Lilex Nerd Font Mono",
    "font_fallbacks": ["Lilex Nerd Font Propo", "Lilex"],
    "cursor_shape": "bar",
    "option_as_meta": true,
  },
  "project_panel": {
    "hide_gitignore": false,
    "auto_fold_dirs": false,
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "play_sound_when_agent_done": true,
    "tool_permissions": {
      "default": "allow",
      "tools": {},
    },
    "enabled": true,
    "button": true,
    "favorite_models": [],
    "model_parameters": [],
  },
  "preview_tabs": {
    "enabled": false,
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "gutter": {
    "folds": true,
  },
  "scrollbar": {
    "axes": {
      "vertical": true,
    },
  },
  "current_line_highlight": "all",
  "cursor_blink": false,
  "buffer_font_fallbacks": ["Lilex Nerd Font Propo", "Lilex"],
  "buffer_font_family": "Lilex Nerd Font Mono",
  "file_types": {
    "json": ["*.{json,jsonc,jsonl}"],
    "shellscript": [
