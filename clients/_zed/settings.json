    "vue": ["*.vue"],
    "plistEditor.bplistedit": ["*.plist"],
    "typescript": ["*.{js,jsx,ts,tsx,cjs,mjs}"],
    "yaml": ["*.{yml,yaml,colors}"],
    "chatagent": ["*.agent.md"],
    "html": ["*.{html,htmx,htm,html5}"],
    "prompt": ["*.prompt.md"],
    "css": ["*.{css,scss,sass,postcss,uss,styl}"],
    "instructions": ["*.instructions.md"],
