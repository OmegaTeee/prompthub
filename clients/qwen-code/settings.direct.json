{
  "$version": 3,
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "env": {
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
    "LM_API_TOKEN": "${LMSTUDIO_API_KEY}",
    "LM_BASE_URL": "http://127.0.0.1:1234/v1",
    "PROMPTHUB_API_KEY": "sk-prompthub-qwen-code-001"
  },
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(brew:*)",
      "Bash(chmod +x:*)",
      "Bash(gh pr:*)",
      "Bash(git rm:*)",
      "Bash(git worktree:*)",
      "Bash(launchctl list *)",
      "Bash(lsof:*)",
      "Bash(npm:*)",
      "Bash(python3:*)",
      "Bash(source:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "WebFetch(qwen.ai)",
      "WebFetch(raw.githubusercontent.com)"
    ]
  },
  "model": {
    "name": "qwen3-4b-thinking-2507"
  },
  "fastModel": "qwen3-0.6b",
  "modelProviders": {
    "openai": [
      {
        "id": "qwen/qwen3-vl-4b",
        "name": "Qwen3 VL 4B",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}",
        "customHeaders": {
          "Authorization": "Bearer ${LM_API_TOKEN}",
          "Content-Type": "application/json",
          "X-Client-Name": "qwen-code"
        },
        "generationConfig": {
          "modalities": {
            "image": true,
            "video": true,
            "audio": true
          },
          "extra_body": {
            "enable_thinking": true
          }
        }
      },
      {
        "id": "qwen3-4b-thinking-2507",
        "name": "LM Studio · Qwen3 4B Thinking 2507",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}",
        "customHeaders": {
          "Authorization": "Bearer ${LM_API_TOKEN}",
          "Content-Type": "application/json",
          "X-Client-Name": "qwen-code"
        },
        "extra_body": {
          "enable_thinking": true
        },
        "capabilities": {
          "tools": true
        }
      },
      {
        "id": "qwen3-4b-instruct-2507",
        "name": "LM Studio · Qwen3 4B Instruct 2507",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}",
        "customHeaders": {
          "Authorization": "Bearer ${LM_API_TOKEN}",
          "Content-Type": "application/json",
          "X-Client-Name": "qwen-code"
        },
        "capabilities": {
          "tools": true
        }
      },
      {
        "id": "qwen3-0.6b",
        "name": "Qwen3 0.6B",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}",
        "customHeaders": {
          "Authorization": "Bearer ${LM_API_TOKEN}",
          "Content-Type": "application/json",
          "X-Client-Name": "qwen-code"
        }
      },
      {
        "id": "qwen2.5-coder-14b-instruct",
        "name": "LM Studio · Qwen2.5 Coder 14B Instruct",
        "type": "code-generation",
        "description": "A powerful 14B-parameter model optimized for complex code generation, large-scale software systems, and multi-file architecture development. Best suited for full-stack applications, enterprise-level codebases, or when high accuracy in logic and structure is required.",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}"
      },
      {
        "id": "qwen2.5-coder-7b-instruct",
        "name": "LM Studio · Qwen2.5 Coder 7B Instruct",
        "description": "A balanced 7B-parameter model that delivers strong performance across both simple and moderately complex code tasks. Perfect for daily coding, API integration, or generating functions and classes with good readability.",
        "type": "code-generation",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}"
      },
      {
        "id": "qwen2.5-coder-3b-instruct",
        "name": "LM Studio · Qwen2.5 Coder 3B Instruct",
        "type": "code-generation",
        "description": "A lightweight 3B-parameter model ideal for fast, responsive code suggestions in simple scripts or small projects. Great for beginners or low-latency environments where quick turnaround is needed.",
        "envKey": "${LM_API_TOKEN}",
        "baseUrl": "${LM_BASE_URL}"
      }
    ]
  },
  "mcp": {
    "allowed": [
      "prompthub-bridge"
    ]
  }
}
