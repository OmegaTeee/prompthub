{
  "$version": 3,
  "ide": {
    "enabled": true,
    "hasSeenNudge": true
  },
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(brew:*)",
      "Bash(chmod +x:*)",
      "Bash(gh pr:*)",
      "Bash(git rm:*)",
      "Bash(git worktree:*)",
      "Bash(launchctl list *)",
      "Bash(lsof:*)",
      "Bash(npm:*)",
      "Bash(python3:*)",
      "Bash(source:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "WebFetch(duckduckgo.com)",
      "WebFetch(github.com)",
      "WebFetch(google.com)",
      "WebFetch(perplexity.ai)",
      "WebFetch(qwen.ai)",
      "WebFetch(raw.githubusercontent.com)"
    ]
  },
  "env": {
    "LM_API_TOKEN": "${LM_API_TOKEN}",
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
    "PROMPTHUB_API_KEY": "${PROMPTHUB_QWEN_CODE_TOKEN}"
  },
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "model": {
    "name": "qwen2.5-coder-7b-instruct"
  },
  "fastModel": "qwen2.5-coder-3b-instruct",
  "modelProviders": {
    "openai": [
      {
        "id": "qwen2.5-coder-3b-instruct",
        "name": "qwen2.5-coder-3b-instruct",
        "baseUrl": "http://127.0.0.1:1234/v1",
        "envKey": "LM_API_TOKEN"
      },
      {
        "id": "qwen2.5-coder-7b-instruct",
        "name": "qwen2.5-coder-7b-instruct",
        "baseUrl": "http://127.0.0.1:9090/v1",
        "envKey": "PROMPTHUB_API_KEY"
      },
      {
        "id": "qwen2.5-coder-14b-instruct",
        "name": "qwen2.5-coder-14b-instruct",
        "baseUrl": "http://127.0.0.1:9090/v1",
        "envKey": "PROMPTHUB_API_KEY"
      },
      {
        "id": "qwen/qwen3-next-80b-a3b-instruct:free",
        "name": "qwen/qwen3-next-80b-a3b-instruct:free",
        "baseUrl": "https://openrouter.ai/api/v1",
        "envKey": "OPENROUTER_API_KEY"
      }
    ]
  }
}
