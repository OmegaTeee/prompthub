{
  "mcpServers": {
    "prompthub-bridge": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/Users/visualval/prompthub/mcps/prompthub-bridge.js"
      ],
      "env": {
        "PROMPTHUB_URL": "http://127.0.0.1:9090",
        "AUTHORIZATION": "Bearer sk-prompthub-cherry-studio-001",
        "CLIENT_NAME": "cherry-studio",
        "SERVERS": "memory,context7,sequential-thinking,desktop-commander,perplexity-comet"
      },
      "headers": {
        "Authorization": "Bearer sk-prompthub-cherry-studio-001",
        "X-Client-ID": "cherry-studio",
        "Content-Type": "application/json"
      }
    },
    "skills-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "skills-mcp",
        "-s",
        "/Users/visualval/.claude/skills"
      ]
    },
    "fetch": {
      "type": "stdio",
      "command": "/Users/visualval/.local/bin/mcp-server-fetch"
    }
  }
}
